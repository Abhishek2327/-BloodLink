# Port configuration for local backend server
PORT=5555

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/BloodLink?retryWrites=true&w=majority

# Resend API key for email notifications (e.g. OTP validation, completion certificate delivery)
RESEND_API_KEY=your_resend_api_key_here

# Frontend CORS origin URL
FRONTEND_URL=http://localhost:1234

# Node environment mode (development or production)
NODE_ENV=development
